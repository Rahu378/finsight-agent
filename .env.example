# FinSight AI Agent — Environment Configuration
# Copy to .env and fill in your values. Never commit .env to Git.

# AWS Configuration
AWS_DEFAULT_REGION=us-east-1
AWS_PROFILE=default
# OR use explicit credentials (prefer IAM roles in production):
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# Bedrock Model Selection
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.1

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# LangSmith (optional — for tracing / debugging in development)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_key
# LANGCHAIN_PROJECT=finsight-agent
